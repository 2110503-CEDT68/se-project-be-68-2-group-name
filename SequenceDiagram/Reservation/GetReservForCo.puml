@startuml Get Reservations for CoworkingSpace (GET)

header Sample Coworking Sequence Diagram
title "Get Reservations for CoworkingSpace (GET) [Admin]"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:reservations" as routerResv
participant "<<middleware>>\n:auth" as middlewareAuth
participant "<<controllers>>\n:reservations" as controllersResv
participant "<<model>>\n:Reservation" as modelResv
database "<<MongoDB>>\n:reservations" as ResvDatabase

client->server ++: req.get('/api/v1/coworkingspaces/{coworkingSpaceId}/reservations')\nAuthorization: Bearer <admin token>
server->routerResv ++: router.use('/:coworkingSpaceId/reservations', reservations)

routerResv->middlewareAuth ++: protect()
middlewareAuth-->routerResv --: next()

routerResv->controllersResv ++: getReservations()
controllersResv->modelResv ++: find({coworkingSpace: id}).populate('coworkingSpace')
modelResv->ResvDatabase ++: query reservations by coworkingSpaceId
ResvDatabase-->modelResv --: reservations[]
controllersResv->client --: 200 response {success, count, data}

@enduml