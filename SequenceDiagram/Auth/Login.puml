@startuml Login (POST)

header Sample Coworking Sequence Diagram
title "Login (POST)"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:auth" as routerAuth
participant "<<controllers>>\n:auth" as controllersAuth
participant "<<model>>\n:User" as modelUser
database "<<MongoDB>>\n:users" as UsersDatabase

client->server ++: req.post('/api/v1/auth/login')
server->routerAuth ++: app.use('/api/v1/auth', auth)
routerAuth -> controllersAuth ++: login()
controllersAuth->modelUser ++: findOne({email}).select('+password')
modelUser->UsersDatabase ++: query users
UsersDatabase-->modelUser --: user (or null)

alt user not found
  controllersAuth->client --: 400 Invalid credentials
else user found
  controllersAuth->controllersAuth ++: matchPassword(password)
  alt password not match
    controllersAuth->client --: 401 Invalid credentials
  else password match
    controllersAuth->controllersAuth ++: sendTokenResponse(user)
    controllersAuth->client --: response {success, token}
  end
end

@enduml